# Firebase service account key path (JSON). Get from Firebase Console > Project Settings > Service Accounts.
# Or set GOOGLE_APPLICATION_CREDENTIALS in your environment.
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Optional: use default credentials (e.g. in Cloud Run / GCP)
# Leave FIREBASE_SERVICE_ACCOUNT_PATH empty to use ADC.

PORT=4000

# CORS origin for frontend
CORS_ORIGIN=${FRONTEND_ORIGIN}
